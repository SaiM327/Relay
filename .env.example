# Slack app credentials (api.slack.com/apps -> your app)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Reaction threshold that triggers the pipeline (distinct reactors)
REACTION_THRESHOLD=3

# SQLite for local/dev; swap for a Postgres URL in prod
DATABASE_URL=sqlite:///devflow.db

# Fine-grained PAT for the target repo: Issues read/write + Contents read
# (github.com -> Settings -> Developer settings -> Fine-grained tokens)
GITHUB_TOKEN=ghp_...
# The repo issues/PRs are filed against, as owner/name
GITHUB_REPO=owner/repo
# Where generated plan.md files are written (optional, default: plans/)
PLANS_DIR=plans
# Command run inside the repo sandbox to verify the coding agent's changes,
# e.g. "pytest -q" or "npm test". Empty = skip verification.
TARGET_REPO_TEST_CMD=

# Shared secret for the GitHub webhook (target repo -> Settings -> Webhooks).
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
GITHUB_WEBHOOK_SECRET=
# Slack channel ID for shipped-feature announcements (optional, e.g. C0123456789)
TEAM_CHANNEL_ID=
# Free key from https://aistudio.google.com/apikey (also used by Gemini CLI).
# Leave empty to use the keyword heuristic for reply classification instead.
GEMINI_API_KEY=

# Flask
PORT=3000
